# yamllint config for this repo. Relaxed so GitHub/Gitea Actions YAML passes
# (the `on:` key would otherwise trip the `truthy` rule) while still catching
# real mistakes. Long lines are a warning, not an error.
extends: default

rules:
  line-length:
    max: 120
    level: warning
  document-start: disable
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
