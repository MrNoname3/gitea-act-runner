# --- Secrets — must NEVER be committed ---

# Registration token + instance settings. Copy runner.env.example -> runner.env.
runner.env

# Runner identity created after registration (contains a secret UUID that
# authenticates this runner to Gitea). Machine-specific; keep the dir, drop
# its contents.
/data/*
!/data/.gitkeep

# --- Machine-specific, generated — not secret but not portable ---

# Rendered by scripts/setup.sh from config.yaml.template + the CI_* resource
# limits in runner.env. Per-machine (RAM/CPU/capacity differ), so it is not
# committed. Edit config.yaml.template or runner.env, then re-run setup.sh.
/config.yaml

# --- Local / tooling junk ---
.claude/
*.log
