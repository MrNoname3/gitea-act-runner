# Podman Quadlet unit for the Gitea Actions runner.
#
# NOTE: __CI_RUNNER_DIR__ is a placeholder. Do NOT copy this file directly into
# ~/.config/containers/systemd/. Run `scripts/setup.sh`, which substitutes the
# repo's absolute path and installs the processed unit. See README.md.

[Unit]
Description=Gitea Actions runner (act_runner)
Wants=network-online.target
After=network-online.target podman.socket

[Container]
# Pinned to a version (not :latest) so Renovate can propose updates via a PR;
# apply a bump with `git pull && ./scripts/setup.sh`. This PR flow is the single
# update path — we deliberately do NOT set `AutoUpdate=registry`, which would fight
# the pin and the Renovate-controlled flow (and silently move the runner version
# out from under the committed config). See renovate.json.
Image=docker.io/gitea/act_runner:0.6.1
ContainerName=gitea-runner
EnvironmentFile=__CI_RUNNER_DIR__/runner.env
Volume=__CI_RUNNER_DIR__/config.yaml:/config.yaml:ro
Volume=__CI_RUNNER_DIR__/data:/data
# Give the runner the host's rootless podman socket so it can start job
# containers. %t = XDG_RUNTIME_DIR (portable across machines/users).
Volume=%t/podman/podman.sock:/var/run/docker.sock
# Needed on SELinux systems so the container may access the mounted socket.
# Harmless on non-SELinux hosts.
SecurityLabelDisable=true

[Service]
Restart=on-failure
RestartSec=10

[Install]
# With lingering enabled, default.target is reached at boot -> starts on boot.
WantedBy=default.target
