# Copy this file to `runner.env` and fill in the values below.
# `runner.env` is gitignored because it holds the registration token (a secret).
#
#   cp runner.env.example runner.env
#   ${EDITOR:-nano} runner.env
#
# ---------------------------------------------------------------------------

# Public base URL of the Gitea instance (must be reachable from this machine).
GITEA_INSTANCE_URL=https://gitea.example.com

# One-time registration token from Gitea:
#   Site Administration -> Actions -> Runners -> Create new Runner
# Only consumed on the FIRST start (when data/.runner does not exist yet).
# After that it can stay as-is; it is ignored.
GITEA_RUNNER_REGISTRATION_TOKEN=REPLACE_WITH_REGISTRATION_TOKEN

# Display name shown in the Gitea runners list. Use something per-machine.
GITEA_RUNNER_NAME=desktop-runner

# Path INSIDE the container to the config file (mounted read-only by the
# quadlet). Leave as-is unless you know why you are changing it.
CONFIG_FILE=/config.yaml
