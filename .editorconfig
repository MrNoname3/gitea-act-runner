# EditorConfig: editor-agnostic enforcement of the project's whitespace rules,
# applied in VS Code by the recommended EditorConfig extension. Mirrors the
# indentation used across this repo (shell, YAML, JSON are all 2-space).
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown: two trailing spaces are a hard line break, so don't strip them.
[*.md]
trim_trailing_whitespace = false
